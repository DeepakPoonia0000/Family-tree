  <div class="flex w-full items-center justify-between gap-4 rounded-full bg-white/15 px-5 py-3 shadow-[0_12px_40px_rgba(56,56,51,0.06)] backdrop-blur-3xl border border-white/20 ring-1 ring-white/10 md:px-8">
    <a class="font-headline text-2xl italic text-primary" href="/">The Living Scrapbook</a>

    <div class="hidden flex-1 items-center justify-center gap-6 text-sm font-semibold text-on-surface-variant md:flex">
      <a class="hover:text-primary transition-colors" href="/dashboard">Dashboard</a>
      <a class="hover:text-primary transition-colors" href="/">Family Tree</a>
      <a class="hover:text-primary transition-colors" href="/news">News</a>
      <a class="hover:text-primary transition-colors" href="/calendar">Calendar</a>
      <a class="hover:text-primary transition-colors" href="/map">Map</a>
      <a class="hover:text-primary transition-colors" href="/gallery">Gallery</a>
      <a class="hover:text-primary transition-colors" href="/recipes">Recipes</a>
      <a class="hover:text-primary transition-colors" href="/archives">Archives</a>
      <a class="hover:text-primary transition-colors" href="/discussions">Discussions</a>
    </div>

    <div class="flex items-center gap-3">
      <a class="hidden rounded-full bg-primary px-4 py-2 text-xs font-bold text-white transition-all hover:bg-primary-dim md:inline-flex" href="<%= isAdmin ? '/admin' : '/admin/login' %>"><%= isAdmin ? 'Admin' : 'Login' %></a>
      <button id="mobileMenuButton" type="button" class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-outline/30 bg-surface text-on-surface shadow-sm transition hover:border-primary md:hidden">
        <span class="material-symbols-outlined text-xl">menu</span>
      </button>
    </div>
  </div>

  <div id="mobileSidebar" class="fixed inset-y-0 right-0 z-50 hidden w-full max-w-xs transform bg-surface px-6 py-8 shadow-2xl transition duration-300 md:hidden">
    <div class="mb-8 flex items-center justify-between">
      <a class="font-headline text-2xl italic text-primary" href="/">The Living Scrapbook</a>
      <button id="mobileSidebarClose" type="button" class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-outline/30 bg-surface text-on-surface shadow-sm transition hover:border-primary">
        <span class="material-symbols-outlined text-xl">close</span>
      </button>
    </div>
    <div class="flex flex-col gap-4 text-sm font-semibold text-on-surface-variant">
      <a class="rounded-2xl px-4 py-3 transition hover:bg-surface-container-high hover:text-primary" href="/dashboard">Dashboard</a>
      <a class="rounded-2xl px-4 py-3 transition hover:bg-surface-container-high hover:text-primary" href="/">Family Tree</a>
      <a class="rounded-2xl px-4 py-3 transition hover:bg-surface-container-high hover:text-primary" href="/news">News</a>
      <a class="rounded-2xl px-4 py-3 transition hover:bg-surface-container-high hover:text-primary" href="/calendar">Calendar</a>
      <a class="rounded-2xl px-4 py-3 transition hover:bg-surface-container-high hover:text-primary" href="/map">Map</a>
      <a class="rounded-2xl px-4 py-3 transition hover:bg-surface-container-high hover:text-primary" href="/gallery">Gallery</a>
      <a class="rounded-2xl px-4 py-3 transition hover:bg-surface-container-high hover:text-primary" href="/recipes">Recipes</a>
      <a class="rounded-2xl px-4 py-3 transition hover:bg-surface-container-high hover:text-primary" href="/archives">Archives</a>
      <a class="rounded-2xl px-4 py-3 transition hover:bg-surface-container-high hover:text-primary" href="/discussions">Discussions</a>
    </div>
    <div class="mt-8">
      <a class="inline-flex w-full items-center justify-center rounded-full bg-primary px-4 py-3 text-sm font-bold text-white transition hover:bg-primary-dim" href="<%= isAdmin ? '/admin' : '/admin/login' %>"><%= isAdmin ? 'Admin' : 'Login' %></a>
    </div>
  </div>

  <div id="mobileBackdrop" class="fixed inset-0 z-40 hidden bg-black/40 backdrop-blur-sm md:hidden"></div>

  <script>
    (() => {
      const button = document.getElementById('mobileMenuButton');
      const sidebar = document.getElementById('mobileSidebar');
      const closeButton = document.getElementById('mobileSidebarClose');
      const backdrop = document.getElementById('mobileBackdrop');
      const toggle = (show) => {
        sidebar.classList.toggle('hidden', !show);
        backdrop.classList.toggle('hidden', !show);
        document.body.style.overflow = show ? 'hidden' : '';
      };
      button?.addEventListener('click', () => toggle(true));
      closeButton?.addEventListener('click', () => toggle(false));
      backdrop?.addEventListener('click', () => toggle(false));
    })();
  </script>
</nav>
