<%- include('../partials/tailwind-head') %>
<%- include('../partials/tailwind-nav') %>

<main class="pt-28 px-6 md:px-12 max-w-7xl mx-auto space-y-16 pb-20">
  <section class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-secondary to-secondary/20 p-10 md:p-16 text-on-primary shadow-soft">
    <div class="relative z-10 max-w-3xl">
      <p class="text-xs font-bold uppercase tracking-[0.3em] text-surface-variant">News & Events</p>
      <h1 class="mt-4 text-5xl md:text-6xl font-headline leading-tight">Latest family stories</h1>
      <p class="mt-5 max-w-2xl text-lg md:text-xl text-on-primary/80">All news and announcements are managed from the admin panel, keeping the family informed with every update.</p>
    </div>
    <div class="pointer-events-none absolute -left-20 top-10 h-72 w-72 rounded-full bg-primary-container/40 blur-3xl"></div>
    <div class="pointer-events-none absolute right-10 bottom-10 h-44 w-44 rounded-full bg-surface/40 blur-3xl"></div>
  </section>

  <% if (!items.length) { %>
    <section class="rounded-3xl border border-outline/30 bg-surface p-10 text-center shadow-soft">
      <h2 class="font-headline text-3xl">No news items yet</h2>
      <p class="mt-4 text-on-surface-variant">Add new posts in admin and they'll appear here instantly.</p>
      <a class="mt-8 inline-flex rounded-full bg-primary px-8 py-3 text-sm font-semibold text-white hover:bg-primary-dim transition" href="/admin/login">Go to Admin</a>
    </section>
  <% } else { %>
    <section class="grid gap-8 lg:grid-cols-[1.4fr_0.6fr]">
      <div class="space-y-8">
        <% const featured = items[0]; %>
        <article class="rounded-3xl overflow-hidden bg-surface shadow-soft border border-outline/30">
          <% if (featured.imageUrl) { %>
            <img src="<%= featured.imageUrl %>" alt="<%= featured.title %>" class="h-96 w-full object-cover" />
          <% } else { %>
            <div class="h-96 bg-surface-soft flex items-center justify-center text-on-surface-variant">No image available</div>
          <% } %>
          <div class="p-8">
            <p class="text-xs uppercase tracking-[0.3em] text-secondary"><%= featured.tag || 'Featured' %></p>
            <h2 class="mt-4 text-4xl font-headline"><%= featured.title %></h2>
            <p class="mt-4 text-on-surface-variant"><%= featured.description || featured.subtitle || 'A recent announcement from the family.' %></p>
            <div class="mt-6 flex flex-wrap gap-3 text-sm text-on-surface-variant">
              <% if (featured.eventDate) { %><span class="rounded-full bg-surface-soft px-3 py-1">Date: <%= new Date(featured.eventDate).toLocaleDateString() %></span><% } %>
              <% if (featured.location) { %><span class="rounded-full bg-surface-soft px-3 py-1">Location: <%= featured.location %></span><% } %>
              <% if (featured.host) { %><span class="rounded-full bg-surface-soft px-3 py-1">Host: <%= featured.host %></span><% } %>
            </div>
          </div>
        </article>
      </div>

      <aside class="space-y-6">
        <% items.slice(1).forEach(function(item) { %>
          <article class="rounded-3xl border border-outline/30 bg-surface p-6 shadow-sm">
            <p class="text-xs uppercase tracking-[0.3em] text-on-surface-variant"><%= item.tag || 'Update' %></p>
            <h3 class="mt-3 text-2xl font-headline"><%= item.title %></h3>
            <p class="mt-3 text-sm text-on-surface-variant"><%= item.description ? item.description.slice(0, 120) : item.subtitle || '' %></p>
          </article>
        <% }) %>
      </aside>
    </section>
  <% } %>
</main>

<%- include('../partials/tailwind-footer') %>
