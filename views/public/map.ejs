<%- include('../partials/tailwind-head') %>
<%- include('../partials/tailwind-nav') %>

<main class="pt-28 px-6 md:px-12 max-w-7xl mx-auto space-y-16 pb-20">
  <section class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-secondary to-secondary/10 p-10 md:p-16 text-on-primary shadow-soft">
    <div class="relative z-10 max-w-3xl">
      <p class="text-xs font-bold uppercase tracking-[0.3em] text-secondary/70">Family Map</p>
      <h1 class="mt-4 text-5xl md:text-6xl font-headline leading-tight">Roots around the world</h1>
      <p class="mt-5 max-w-2xl text-lg md:text-xl text-on-primary/80">A living list of family locations and stories, all managed by the admin team.</p>
    </div>
    <div class="pointer-events-none absolute left-10 top-10 h-56 w-56 rounded-full bg-primary-container/40 blur-3xl"></div>
    <div class="pointer-events-none absolute right-10 bottom-10 h-44 w-44 rounded-full bg-surface/40 blur-3xl"></div>
  </section>

  <section class="grid gap-8 lg:grid-cols-[1.6fr_0.9fr]">
    <article class="relative rounded-3xl border border-outline/30 bg-surface p-8 shadow-soft">
      <div id="familyMap" class="h-[420px] w-full overflow-hidden rounded-3xl border border-dashed border-outline/50"></div>
      <% if (!items.length) { %>
        <div class="absolute inset-0 grid place-items-center rounded-3xl bg-surface/80 text-center p-6">
          <div class="max-w-sm">
            <span class="material-symbols-outlined text-6xl text-primary">public</span>
            <p class="mt-4 text-2xl font-headline">Map view coming soon</p>
            <p class="mt-3 text-sm text-on-surface-variant">Add member coordinates in admin and they will appear here automatically.</p>
          </div>
        </div>
      <% } %>
    </article>

    <aside class="space-y-6">
      <% if (!items.length) { %>
        <div class="rounded-3xl border border-outline/30 bg-surface p-8 text-center text-on-surface-variant shadow-soft">
          No members with coordinates have been added yet. Add latitude and longitude on member profiles in admin to populate the map.
        </div>
      <% } else { %>
        <% items.forEach(function(item) { %>
          <div class="rounded-3xl border border-outline/30 bg-surface p-6 shadow-sm">
            <div class="flex items-center justify-between gap-4">
              <h2 class="font-headline text-2xl"><%= item.fullName %></h2>
              <span class="rounded-full bg-primary-container px-3 py-1 text-xs font-semibold text-on-primary-container"><%= item.relationship || 'Family member' %></span>
            </div>
            <p class="mt-3 text-sm text-on-surface-variant"><%= item.birthPlace ? item.birthPlace + '.' : 'Location details not available.' %></p>
            <p class="mt-3 text-sm text-on-surface-variant">Latitude: <%= item.latitude %>, Longitude: <%= item.longitude %></p>
          </div>
        <% }) %>
      <% } %>
    </aside>
  </section>
</main>

<% if (items.length) { %>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script>
    (function() {
      const members = <%- JSON.stringify(items.map((item) => ({
        fullName: item.fullName,
        relationship: item.relationship,
        birthPlace: item.birthPlace,
        latitude: item.latitude,
        longitude: item.longitude,
        slug: item.slug
      }))) %>;

      if (!members.length) return;

      const latitudes = members.map((m) => m.latitude);
      const longitudes = members.map((m) => m.longitude);
      const centerLat = latitudes.reduce((sum, value) => sum + value, 0) / latitudes.length;
      const centerLng = longitudes.reduce((sum, value) => sum + value, 0) / longitudes.length;

      const map = L.map('familyMap', {
        center: [centerLat, centerLng],
        zoom: 2,
        scrollWheelZoom: false
      });

      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors',
        maxZoom: 18
      }).addTo(map);

      members.forEach((member) => {
        if (member.latitude == null || member.longitude == null) return;

        const marker = L.marker([member.latitude, member.longitude]).addTo(map);
        marker.bindPopup(`
          <div style="max-width: 240px;">
            <strong>${member.fullName}</strong><br />
            ${member.relationship ? `<span style="font-size:0.9rem;color:#6b7280;">${member.relationship}</span><br />` : ''}
            ${member.birthPlace ? `<span style="font-size:0.85rem;color:#6b7280;">${member.birthPlace}</span><br />` : ''}
            <a href="/members/${member.slug}" style="color:#1d4ed8; text-decoration:none; font-weight:600;">View profile</a>
          </div>
        `);
      });

      const bounds = L.latLngBounds(members.map((member) => [member.latitude, member.longitude]));
      if (members.length > 1) {
        map.fitBounds(bounds.pad(0.25));
      }
    })();
  </script>
<% } %>

<%- include('../partials/tailwind-footer') %>
