<%- include('../partials/tailwind-head') %>
<%- include('../partials/tailwind-nav') %>

<main class="pt-28 px-6 md:px-12 max-w-7xl mx-auto space-y-16 pb-20">
  <section class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-primary to-primary-container p-10 md:p-16 text-on-primary shadow-soft">
    <div class="relative z-10 max-w-3xl">
      <p class="text-xs font-bold uppercase tracking-[0.3em] text-primary/80">Achievements Gallery</p>
      <h1 class="mt-4 text-5xl md:text-6xl font-headline leading-tight">Memories worth celebrating</h1>
      <p class="mt-5 max-w-2xl text-lg md:text-xl text-primary/90">Gallery entries are published by the admin team and presented here with every milestone and memory.</p>
    </div>
    <div class="pointer-events-none absolute left-10 top-10 h-56 w-56 rounded-full bg-surface/40 blur-3xl"></div>
    <div class="pointer-events-none absolute right-10 bottom-10 h-44 w-44 rounded-full bg-secondary/20 blur-3xl"></div>
  </section>

  <% if (!items.length) { %>
    <section class="rounded-3xl border border-outline/30 bg-surface p-10 text-center shadow-soft">
      <h2 class="font-headline text-3xl">No gallery items yet</h2>
      <p class="mt-4 text-on-surface-variant">Add photos, milestones, and memories through admin, and they will appear here beautifully.</p>
    </section>
  <% } else { %>
    <section class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <% items.forEach(function(item, idx) { %>
        <article class="overflow-hidden rounded-[2rem] border border-outline/30 bg-surface shadow-sm transition hover:-translate-y-1">
          <div class="relative h-72 overflow-hidden bg-surface-soft">
            <% if (item.imageUrl) { %>
              <img src="<%= item.imageUrl %>" alt="<%= item.title %>" class="h-full w-full object-cover transition duration-500 hover:scale-105" />
            <% } else { %>
              <div class="flex h-full items-center justify-center text-on-surface-variant">No image available</div>
            <% } %>
          </div>
          <div class="p-6">
            <p class="text-xs uppercase tracking-[0.3em] text-on-surface-variant"><%= item.tag || ('Highlight ' + (idx + 1)) %></p>
            <h2 class="mt-3 font-headline text-2xl"><%= item.title %></h2>
            <p class="mt-3 text-sm text-on-surface-variant"><%= item.description || item.subtitle || 'A shared family moment.' %></p>
          </div>
        </article>
      <% }) %>
    </section>
  <% } %>
</main>

<%- include('../partials/tailwind-footer') %>
