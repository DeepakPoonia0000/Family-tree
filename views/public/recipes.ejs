<%- include('../partials/tailwind-head') %>
<%- include('../partials/tailwind-nav') %>

<main class="pt-28 px-6 md:px-12 max-w-7xl mx-auto space-y-16 pb-20">
  <section class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-tertiary-container to-tertiary-fixed p-10 md:p-16 text-on-primary shadow-soft">
    <div class="relative z-10 max-w-3xl">
      <p class="text-xs font-bold uppercase tracking-[0.3em] text-primary/80">Family Recipes</p>
      <h1 class="mt-4 text-5xl md:text-6xl font-headline leading-tight">Kitchen heritage</h1>
      <p class="mt-5 max-w-2xl text-lg md:text-xl text-on-primary/80">Family recipes preserved in one place. All entries are added by the admin team and shown here automatically.</p>
    </div>
    <div class="pointer-events-none absolute left-10 top-10 h-56 w-56 rounded-full bg-primary/10 blur-3xl"></div>
    <div class="pointer-events-none absolute right-10 bottom-10 h-44 w-44 rounded-full bg-secondary/20 blur-3xl"></div>
  </section>

  <% if (!items.length) { %>
    <section class="rounded-3xl border border-outline/30 bg-surface p-10 text-center shadow-soft">
      <h2 class="font-headline text-3xl">No recipes yet</h2>
      <p class="mt-4 text-on-surface-variant">Add dishes and family favorites through the admin panel, and they will appear here for everyone to enjoy.</p>
    </section>
  <% } else { %>
    <section class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      <% items.forEach(function(item) { %>
        <article class="rounded-3xl border border-outline/30 bg-surface p-6 shadow-sm transition hover:-translate-y-1">
          <div class="flex items-center justify-between gap-4">
            <p class="text-xs uppercase tracking-[0.3em] text-on-surface-variant"><%= item.tag || 'Recipe' %></p>
            <% if (item.period) { %><span class="rounded-full bg-surface-soft px-3 py-1 text-xs font-semibold text-on-surface-variant"><%= item.period %></span><% } %>
          </div>
          <h2 class="mt-4 font-headline text-2xl"><%= item.title %></h2>
          <p class="mt-4 text-sm text-on-surface-variant"><%= item.description || item.subtitle || 'A treasured family recipe.' %></p>
        </article>
      <% }) %>
    </section>
  <% } %>
</main>

<%- include('../partials/tailwind-footer') %>
