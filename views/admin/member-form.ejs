<%- include('../partials/tailwind-head') %>
<%- include('../partials/tailwind-nav') %>

<main class="mx-auto mt-8 max-w-5xl px-4">
  <section class="rounded-3xl border border-outline/40 bg-surface p-6 shadow-soft">
    <h1 class="font-headline text-5xl"><%= formTitle %></h1>
    <p class="mt-2 text-sm text-on-surface-variant">Add or update family members and relationship data.</p>

    <form method="post" action="<%= action %>" enctype="multipart/form-data" class="mt-6 grid gap-4 md:grid-cols-2">
      <div>
        <label class="mb-1 block text-sm font-semibold">Full Name</label>
        <input type="text" name="fullName" value="<%= member.fullName || '' %>" required class="w-full rounded-xl border-outline/60 bg-surface-soft" />
      </div>
      <div>
        <label class="mb-1 block text-sm font-semibold">Relationship</label>
        <input type="text" name="relationship" value="<%= member.relationship || '' %>" required class="w-full rounded-xl border-outline/60 bg-surface-soft" />
      </div>
      <div>
        <label class="mb-1 block text-sm font-semibold">Generation</label>
        <input type="number" name="generation" min="1" max="20" value="<%= member.generation || 1 %>" required class="w-full rounded-xl border-outline/60 bg-surface-soft" />
      </div>
      <div>
        <label class="mb-1 block text-sm font-semibold">Birth Place</label>
        <input type="text" name="birthPlace" value="<%= member.birthPlace || '' %>" class="w-full rounded-xl border-outline/60 bg-surface-soft" />
      </div>
      <div>
        <label class="mb-1 block text-sm font-semibold">Latitude</label>
        <input type="number" step="0.000001" name="latitude" value="<%= member.latitude != null ? member.latitude : '' %>" class="w-full rounded-xl border-outline/60 bg-surface-soft" />
      </div>
      <div>
        <label class="mb-1 block text-sm font-semibold">Longitude</label>
        <input type="number" step="0.000001" name="longitude" value="<%= member.longitude != null ? member.longitude : '' %>" class="w-full rounded-xl border-outline/60 bg-surface-soft" />
      </div>
      <div>
        <label class="mb-1 block text-sm font-semibold">Birth Date</label>
        <input type="date" name="birthDate" value="<%= member.birthDate ? new Date(member.birthDate).toISOString().slice(0, 10) : '' %>" class="w-full rounded-xl border-outline/60 bg-surface-soft" />
      </div>
      <div>
        <label class="mb-1 block text-sm font-semibold">Death Date</label>
        <input type="date" name="deathDate" value="<%= member.deathDate ? new Date(member.deathDate).toISOString().slice(0, 10) : '' %>" class="w-full rounded-xl border-outline/60 bg-surface-soft" />
      </div>
      <div class="md:col-span-2">
        <label class="mb-1 block text-sm font-semibold">Photo URL</label>
        <input type="text" name="photoUrl" value="<%= member.photoUrl || '' %>" class="w-full rounded-xl border-outline/60 bg-surface-soft" />
      </div>
      <div class="md:col-span-2">
        <label class="mb-1 block text-sm font-semibold">Upload Photo</label>
        <input type="file" name="photoFile" accept="image/*" class="w-full rounded-xl border-outline/60 bg-surface-soft" />
        <% if (member.photoUrl) { %><p class="mt-1 text-xs text-on-surface-variant">Current: <%= member.photoUrl %></p><% } %>
      </div>
      <div>
        <label class="mb-1 block text-sm font-semibold">Spouse</label>
        <select name="spouseId" class="w-full rounded-xl border-outline/60 bg-surface-soft">
          <option value="">No spouse linked</option>
          <% members.forEach(function(option) { %>
          <option value="<%= option._id %>" <%= member.spouseId && String(member.spouseId) === String(option._id) ? 'selected' : '' %>><%= option.fullName %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="mb-1 block text-sm font-semibold">Parent(s)</label>
        <select name="parentIds" multiple size="5" class="w-full rounded-xl border-outline/60 bg-surface-soft">
          <% members.forEach(function(option) { %>
          <option value="<%= option._id %>" <%= member.parentIds && member.parentIds.map(String).includes(String(option._id)) ? 'selected' : '' %>><%= option.fullName %></option>
          <% }) %>
        </select>
      </div>
      <div class="md:col-span-2">
        <label class="mb-1 block text-sm font-semibold">Biography</label>
        <textarea name="bio" rows="6" class="w-full rounded-xl border-outline/60 bg-surface-soft"><%= member.bio || '' %></textarea>
      </div>
      <div class="md:col-span-2">
        <label class="mb-1 block text-sm font-semibold">Favorite Memory</label>
        <textarea name="favoriteMemory" rows="3" class="w-full rounded-xl border-outline/60 bg-surface-soft"><%= member.favoriteMemory || '' %></textarea>
      </div>
      <div class="md:col-span-2">
        <label class="mb-1 block text-sm font-semibold">Affiliations</label>
        <textarea name="affiliations" rows="4" placeholder="One affiliation per line" class="w-full rounded-xl border-outline/60 bg-surface-soft"><%= (member.affiliations || []).join('\n') %></textarea>
      </div>
      <div class="md:col-span-2">
        <label class="mb-1 block text-sm font-semibold">Milestones</label>
        <textarea name="milestones" rows="5" placeholder="Year | Title | Description" class="w-full rounded-xl border-outline/60 bg-surface-soft"><%= (member.milestones || []).map(function(milestone) { return [milestone.year || '', milestone.title || '', milestone.description || ''].join(' | '); }).join('\n') %></textarea>
      </div>
      <div class="md:col-span-2">
        <label class="mb-1 block text-sm font-semibold">Gallery Image URLs</label>
        <textarea name="galleryImageUrls" rows="4" placeholder="One image URL per line" class="w-full rounded-xl border-outline/60 bg-surface-soft"><%= (member.galleryImageUrls || []).join('\n') %></textarea>
      </div>
      <label class="flex items-center gap-2 md:col-span-2"><input type="checkbox" name="isFeatured" <%= member.isFeatured ? 'checked' : '' %> /> <span class="text-sm font-semibold">Mark as featured</span></label>
      <div class="flex gap-3 md:col-span-2">
        <button type="submit" class="rounded-full bg-primary px-6 py-3 text-sm font-bold text-white">Save Member</button>
        <a href="/admin" class="rounded-full bg-surface-soft px-6 py-3 text-sm font-bold text-on-surface">Cancel</a>
      </div>
    </form>
  </section>
</main>

<%- include('../partials/tailwind-footer') %>
